# OxyGent 模型配置
# 复制此文件为 .env，并填入你的实际密钥

# ================================
# 以下为默认大模型配置（Agent 将默认调用此模型）
# ================================

# 你的 API Key (必填)
DEFAULT_LLM_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 如果使用中转地址或私有部署(如vLLM/Ollama)，在此填写 base_url
# 注意：如果使用原生 OpenAI，可不填或填 "https://api.openai.com/v1"
DEFAULT_LLM_BASE_URL="https://api.openai.com/v1"

# 你要调用的具体模型名称 (如 gpt-4o, gpt-3.5-turbo, qwen2 等)
DEFAULT_LLM_MODEL_NAME="gpt-4o"
